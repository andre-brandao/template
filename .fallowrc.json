{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "packages/ui/src/lib/index.ts",
    "packages/*/src/**/*.test.ts",
    "packages/*/test/**/*.ts",
    "packages/functions/**/*.ts",
    "scripts/**/*.ts",
    "infra/**/*.ts",
    "sst.config.ts",
    "**/build.ts",
    "**/adapter/*.ts"
  ],
  "ignorePatterns": ["**/*.gen.ts"],
  "ignoreDependencies": ["@hono/standard-validator"],
  "ignoreUnresolvedImports": ["@template/ui"],
  "overrides": [{ "files": ["packages/ui/**"], "rules": { "unrendered-components": "off" } }]
}
