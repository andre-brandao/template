{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "libs/*/build.ts",
    "packages/*/src/**/*.test.ts",
    "packages/*/test/**/*.ts",
    "packages/functions/**/*.ts",
    "scripts/**/*.ts",
    "infra/**/*.ts",
    "sst.config.ts"
  ],
  "ignorePatterns": [
    "**/*.gen.ts"
  ],
  "ignoreDependencies": [
    "@hono/standard-validator"
  ]
}
