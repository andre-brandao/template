# Copy to infra/docker/.env before running `docker compose up`.

# --- Postgres container ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=postgres

# --- Database connection (shared by migrate, api, mcp, dashboard) ---
# Host `postgres` is the compose service DNS name. Point this at an external
# managed Postgres instead to skip the bundled db.
DATABASE_URL=postgresql://postgres:password@postgres:5432/postgres

# --- SvelteKit adapter-node ---
# Required for correct form-action and cookie handling behind the proxy/port map.
ORIGIN=http://localhost:3000
# Raise the default 512kb body limit so file uploads (up to File.MAX_SIZE) fit.
BODY_SIZE_LIMIT=10485760

# --- File storage (shared by api and dashboard) ---
# `fs` writes to STORAGE_DIR on disk (see the `filedata` volume in compose.yml).
# `s3` talks to any S3-compatible bucket (AWS S3 or Cloudflare R2) via access keys.
STORAGE_DRIVER=fs
STORAGE_DIR=/data/files
# Uncomment to use S3/R2 instead of the local disk:
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# --- Auth ---
# The OpenAuth issuer. `auth` is the compose service DNS name.
AUTH_URL=http://auth:3002
# Signs dashboard session cookies — set to a long random string.
SESSION_SECRET=change-me
# Optional: comma list to restrict providers, e.g. `code,github`. Empty = password,code (+ any with creds).
# AUTH_PROVIDERS=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# --- App ---
NODE_ENV=production
# The one secret currently modeled in infra/cf/secrets.ts.
EXAMPLE_SECRET=

# Public dashboard URL used in invitation emails (`/invite/<token>` links).
APP_URL=http://localhost:3000

# Optional
# SMTP_FROM=Developing <no.reply@developing.company>
# DRIZZLE_LOG=false
