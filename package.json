{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@dev-template",
  "private": true,
  "workspaces": {
    "catalog": {
      "@openauthjs/openauth": "0.4.3",
      "@types/bun": "1.3.13",
      "drizzle-kit": "^1.0.0-rc.2",
      "drizzle-orm": "^1.0.0-rc.2",
      "hono": "^4.11.3",
      "postgres": "^3.4.8",
      "sst": "4.17.1",
      "typescript": "^7.0.0",
      "ulid": "^3.0.2",
      "zod": "^4.3.5"
    },
    "catalogs": {
      "build": {
        "@hey-api/openapi-ts": "0.99.0"
      },
      "frontend": {
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.69.3",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@tailwindcss/vite": "^4.3.0",
        "svelte": "^5.56.1",
        "svelte-check": "^4.7.2",
        "tailwindcss": "^4.3.0",
        "vite": "^8.1.4"
      },
      "testing": {
        "@happy-dom/global-registrator": "^20.8.9",
        "@playwright/test": "^1.50.0",
        "@testing-library/svelte": "^5.3.1"
      }
    },
    "packages": [
      "packages/*",
      "packages/sdk/ts",
      "apps/*",
      "scripts"
    ]
  },
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules **/node_modules",
    "cli": "bun run apps/cli/src/index.ts",
    "dev": "bun run scripts/dev.ts",
    "docker": "docker compose -f infra/docker/compose.yml",
    "docker:up": "test -f infra/docker/.env || cp infra/docker/.env.example infra/docker/.env; docker compose -f infra/docker/compose.yml up --build -d",
    "docker:logs": "docker compose -f infra/docker/compose.yml logs -f",
    "docker:down": "docker compose -f infra/docker/compose.yml down",
    "fallow": "bunx fallow health --hotspots --top 3 && bunx fallow dead-code && bunx fallow dupes",
    "fallow:dead-code": "bunx fallow dead-code",
    "fallow:dupes": "bunx fallow dupes",
    "fallow:health": "bunx fallow health --hotspots --top 3",
    "fallow:json": "bunx fallow health --hotspots --top 3 --format json --quiet && bunx fallow dead-code --format json --quiet && bunx fallow dupes --format json --quiet",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "gen": "bun run --filter '@template/functions' gen:spec && bun run --filter '@template/sdk' gen",
    "lint": "oxlint",
    "lint:ci": "oxlint -f github",
    "lint:fix": "oxlint --fix",
    "test": "bun --filter '*' test",
    "test:ci": "bun --filter '*' test --reporter=junit --reporter-outfile=junit.xml",
    "test:e2e": "bun run --filter dashboard test:e2e",
    "typecheck": "bun --filter '*' typecheck"
  },
  "dependencies": {
    "sst": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260715.1",
    "@types/bun": "catalog:",
    "fallow": "^3.6.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.13"
}
