{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@dev-template",
  "private": true,
  "workspaces": {
    "catalog": {
      "@types/bun": "1.3.13",
      "postgres": "^3.4.8",
      "drizzle-kit": "^1.0.0-rc.2",
      "drizzle-orm": "^1.0.0-rc.2",
      "hono": "^4.11.3",
      "ulid": "^3.0.2",
      "zod": "^4.3.5",
      "typescript": "^7.0.0"
    },
    "catalogs": {
      "build": {
        "@hey-api/openapi-ts": "0.94.3"
      },
      "frontend": {
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.69.3",
        "@sveltejs/vite-plugin-svelte": "^7.2.0",
        "@tailwindcss/vite": "^4.3.0",
        "svelte": "^5.56.1",
        "svelte-check": "^4.7.2",
        "tailwindcss": "^4.3.0",
        "vite": "^8.1.4"
      },
      "testing": {
        "@happy-dom/global-registrator": "^20.8.9",
        "@testing-library/svelte": "^5.3.1"
      }
    },
    "packages": [
      "packages/*",
      "packages/sdk/ts",
      "apps/*",
      "scripts"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "cli": "bun run apps/cli/src/index.ts",
    "gen": "bun run --filter '@template/functions' gen:spec && bun run --filter '@template/sdk' gen",
    "clean": "rm -rf node_modules **/node_modules",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:ci": "oxlint -f github",
    "lint:fix": "oxlint --fix",
    "test": "bun --filter '*' test",
    "test:ci": "bun --filter '*' test --reporter=junit --reporter-outfile=junit.xml",
    "typecheck": "bun --filter '*' typecheck",
    "fallow": "fallow health --hotspots --top 3 && fallow dead-code && fallow dupes",
    "fallow:health": "fallow health --hotspots --top 3",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:json": "fallow health --hotspots --top 3 --format json --quiet && fallow dead-code --format json --quiet && fallow dupes --format json --quiet"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "fallow": "^3.4.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
