{
  "name": "@template/functions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "module": "src/api/index.ts",
  "exports": {
    ".": "./src/api/index.ts",
    "./api": "./src/api/index.ts",
    "./auth": "./src/auth/index.ts",
    "./auth/*": "./src/auth/*.ts",
    "./mcp": "./src/mcp/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/api/target/bun.ts",
    "dev:mcp": "bun run --hot src/mcp/target/bun.ts",
    "dev:auth": "bun run --hot src/auth/target/bun.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gen:spec": "bun run scripts/gen-spec.ts"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.1",
    "@hono/standard-validator": "^0.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openauthjs/openauth": "catalog:",
    "@template/core": "workspace:*",
    "hono": "catalog:",
    "hono-openapi": "^1.1.2",
    "sst": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  }
}
