{
  "openapi": "3.1.0",
  "info": {
    "title": "Template API",
    "description": "Users, organizations, and todos.",
    "version": "1.0.0"
  },
  "components": {
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer"
      }
    },
    "schemas": {
      "User": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique object identifier.\nThe format and length of IDs may change over time.",
            "example": "usr_XXXXXXXXXXXXXXXXXXXXXXXXX"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "image": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": ["id", "name", "email", "image"],
        "description": "A user account.",
        "example": {
          "id": "usr_XXXXXXXXXXXXXXXXXXXXXXXXX",
          "name": "John Doe",
          "email": "john@example.com",
          "emailVerified": true,
          "image": null
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "validation",
              "authentication",
              "forbidden",
              "not_found",
              "rate_limit",
              "internal"
            ],
            "description": "The error type category",
            "examples": ["validation", "authentication"]
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code identifier",
            "examples": ["invalid_parameter", "missing_required_field", "unauthorized"]
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "examples": ["The request was invalid", "Authentication required"]
          },
          "param": {
            "description": "The parameter that caused the error (if applicable)",
            "examples": ["email", "user_id"],
            "type": "string"
          },
          "details": {
            "description": "Additional error context information"
          }
        },
        "required": ["type", "code", "message"],
        "description": "Not found error"
      },
      "Key": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique object identifier.\nThe format and length of IDs may change over time.",
            "example": "key_XXXXXXXXXXXXXXXXXXXXXXXXX"
          },
          "type": {
            "type": "string",
            "enum": ["session", "api"],
            "description": "`api` keys are user-minted and never expire; `session` keys back a login."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
          },
          "key": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "description": "The secret, for `api` keys only. Null for `session` keys — a login token is never handed back out."
          },
          "display": {
            "type": "string",
            "description": "Masked secret, safe to show in a list."
          },
          "timeUsed": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              {
                "type": "null"
              }
            ],
            "description": "When the key last authenticated a request."
          },
          "expiresAt": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              {
                "type": "null"
              }
            ],
            "description": "When the key stops working. Null for `api` keys."
          },
          "current": {
            "type": "boolean",
            "description": "Whether this is the key authenticating the current request."
          }
        },
        "required": ["id", "type", "name", "key", "display", "timeUsed", "expiresAt", "current"],
        "description": "An API key or an active session belonging to a user.",
        "example": {
          "id": "key_XXXXXXXXXXXXXXXXXXXXXXXXX",
          "type": "api",
          "name": "laptop",
          "key": "sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
          "display": "sk-XXXX...XXXX",
          "timeUsed": null,
          "expiresAt": null,
          "current": false
        }
      },
      "Todo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique object identifier.\nThe format and length of IDs may change over time.",
            "example": "tod_XXXXXXXXXXXXXXXXXXXXXXXXX"
          },
          "userID": {
            "type": "string"
          },
          "title": {
            "type": "string",
            "minLength": 0,
            "maxLength": 2000
          },
          "status": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "description": "Status of a todo item. Any short label; defaults are pending, in_progress and done.",
            "example": "pending"
          },
          "dueDate": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "required": ["id", "userID", "title", "status", "dueDate"],
        "description": "A todo item that belongs to a user.",
        "example": {
          "id": "tod_XXXXXXXXXXXXXXXXXXXXXXXXX",
          "userID": "usr_XXXXXXXXXXXXXXXXXXXXXXXXX",
          "title": "Write the quarterly report",
          "status": "pending",
          "dueDate": null
        }
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ],
  "servers": [
    {
      "description": "Local",
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getMe",
        "tags": ["User"],
        "summary": "Get current user",
        "description": "Get the profile of the currently authenticated user.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/User"
                },
                "example": {
                  "id": "usr_XXXXXXXXXXXXXXXXXXXXXXXXX",
                  "name": "John Doe",
                  "email": "john@example.com",
                  "emailVerified": true,
                  "image": null
                }
              }
            },
            "description": "The current user."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "operationId": "postAuthRegister",
        "tags": ["Auth"],
        "summary": "Register",
        "description": "Create a new user with an email/password and start a session.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userID": {
                      "type": "string",
                      "description": "The logged-in user's ID."
                    },
                    "token": {
                      "type": "string",
                      "description": "Bearer session token. Include as `Authorization: Bearer <token>`."
                    }
                  },
                  "required": ["userID", "token"]
                }
              }
            },
            "description": "New session."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "validation",
                  "code": "invalid_parameter",
                  "message": "The request was invalid"
                }
              }
            },
            "description": "Bad Request"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": ["name", "email", "password"]
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "operationId": "postAuthLogin",
        "tags": ["Auth"],
        "summary": "Login",
        "description": "Exchange an email/password for a new session.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "userID": {
                      "type": "string",
                      "description": "The logged-in user's ID."
                    },
                    "token": {
                      "type": "string",
                      "description": "Bearer session token. Include as `Authorization: Bearer <token>`."
                    }
                  },
                  "required": ["userID", "token"]
                }
              }
            },
            "description": "New session."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "validation",
                  "code": "invalid_parameter",
                  "message": "The request was invalid"
                }
              }
            },
            "description": "Bad Request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
                  },
                  "password": {
                    "type": "string"
                  }
                },
                "required": ["email", "password"]
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "operationId": "postAuthLogout",
        "tags": ["Auth"],
        "summary": "Logout",
        "description": "Invalidate the current session.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "const": "ok"
                }
              }
            },
            "description": "Logged out."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/key": {
      "get": {
        "operationId": "getKey",
        "tags": ["Key"],
        "summary": "List keys",
        "description": "List the current user's API keys and active sessions. Session secrets are withheld; the key authenticating this request is flagged `current`.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Key"
                  }
                },
                "example": [
                  {
                    "id": "key_XXXXXXXXXXXXXXXXXXXXXXXXX",
                    "type": "api",
                    "name": "laptop",
                    "key": "sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
                    "display": "sk-XXXX...XXXX",
                    "timeUsed": null,
                    "expiresAt": null,
                    "current": false
                  }
                ]
              }
            },
            "description": "The user's keys and sessions."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        }
      },
      "post": {
        "operationId": "postKey",
        "tags": ["Key"],
        "summary": "Create key",
        "description": "Mint a named API key for the current user. API keys do not expire.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Key"
                },
                "example": {
                  "id": "key_XXXXXXXXXXXXXXXXXXXXXXXXX",
                  "type": "api",
                  "name": "laptop",
                  "key": "sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX",
                  "display": "sk-XXXX...XXXX",
                  "timeUsed": null,
                  "expiresAt": null,
                  "current": false
                }
              }
            },
            "description": "The created key, including its secret."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "validation",
                  "code": "invalid_parameter",
                  "message": "The request was invalid"
                }
              }
            },
            "description": "Bad Request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 255
                  }
                },
                "required": ["name"]
              }
            }
          }
        }
      }
    },
    "/key/{id}": {
      "delete": {
        "operationId": "deleteKeyById",
        "tags": ["Key"],
        "summary": "Revoke key",
        "description": "Revoke an API key or a session. The secret stops authenticating immediately — revoking your own session logs you out.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "const": "ok"
                }
              }
            },
            "description": "Revoked."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "not_found",
                  "code": "resource_not_found",
                  "message": "The requested resource could not be found"
                }
              }
            },
            "description": "Not Found"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ]
      }
    },
    "/todo": {
      "get": {
        "operationId": "getTodo",
        "tags": ["Todo"],
        "summary": "List todos",
        "description": "List the current user's todos, optionally filtered by status. Paginated.",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Todo"
                      }
                    },
                    "page": {
                      "type": "number",
                      "description": "Page number returned."
                    },
                    "pageSize": {
                      "type": "number",
                      "description": "Number of entities per page."
                    },
                    "total": {
                      "type": "number",
                      "description": "Total number of matching entities across all pages."
                    }
                  },
                  "required": ["data", "page", "pageSize", "total"],
                  "description": "A page of results."
                },
                "example": {
                  "data": [
                    {
                      "id": "tod_XXXXXXXXXXXXXXXXXXXXXXXXX",
                      "userID": "usr_XXXXXXXXXXXXXXXXXXXXXXXXX",
                      "title": "Write the quarterly report",
                      "status": "pending",
                      "dueDate": null
                    }
                  ],
                  "page": 1,
                  "pageSize": 20,
                  "total": 1
                }
              }
            },
            "description": "A page of todos."
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "internal",
                  "code": "internal_error",
                  "message": "Internal server error"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "parameters": [
          {
            "in": "query",
            "name": "page",
            "schema": {
              "type": "number",
              "minimum": 1
            }
          },
          {
            "in": "query",
            "name": "pageSize",
            "schema": {
              "type": "number",
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "description": "Status of a todo item. Any short label; defaults are pending, in_progress and done.",
                "example": "pending"
              }
            }
          }
        ]
      },
      "post": {
        "operationId": "postTodo",
        "tags": ["Todo"],
        "summary": "Create todo",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Todo"
                }
              }
            },
            "description": "The created todo."
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "validation",
                  "code": "invalid_parameter",
                  "message": "The request was invalid"
                }
              }
            },
            "description": "Bad Request"
          },
          "401": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "type": "authentication",
                  "code": "unauthorized",
                  "message": "Authentication required"
                }
              }
            },
            "description": "Unauthorized"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
