{
  "name": "@template/ui",
  "version": "0.0.1",
  "keywords": [
    "svelte"
  ],
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "test": "bun test",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "catalog:testing",
    "@sveltejs/adapter-auto": "catalog:frontend",
    "@sveltejs/kit": "catalog:frontend",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "catalog:frontend",
    "@testing-library/svelte": "catalog:testing",
    "publint": "^0.3.21",
    "svelte": "catalog:frontend",
    "svelte-check": "catalog:frontend",
    "typescript": "catalog:",
    "vite": "catalog:frontend"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  }
}
